# Copy to .env for local overrides (optional).

# Leave unset in dev: Vite proxies /api to http://127.0.0.1:8000 (dama5) when you use corpus / AI.
# Teacher MP3 for AN 11.16 is served from public/aud/ — no backend required (see public/aud/README.txt).
# For production or LAN testing without proxy, set full API origin, e.g.:
# VITE_DAMA_API_URL=https://your-dama-host.run.app
#
# Set on dama5: DAMA_CORS_ORIGINS with the same origin as this app (see dama5 .env.example).

# VITE_DAMA_API_URL=

# Match dama5: use LLM for /api/query (needs Ollama or Vertex). Set false for retrieval-only smoke.
# VITE_DAMA_USE_LLM=true
