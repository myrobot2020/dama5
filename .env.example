# Copy to .env and fill in values. Never commit .env.

# --- Optional layout overrides (defaults: files next to an1_app.py) ---
# DAMA_DATA_DIR=
# AN1_JSON_PATH=
# AN2_JSON_PATH=
# CHROMA_AN1_DIR=
# CHROMA_AN2_DIR=
# DAMA_DEBUG_LOG_PATH=
# DAMA_GONG_MP3=

# --- Vertex / GCP (optional; local Chroma works without these) ---
# AN1_USE_VERTEX=1
# DAMA_USE_VERTEX=1
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_REGION=
# GCP_PROJECT=
# GOOGLE_CLOUD_LOCATION=
# AN1_VERTEX_EMBEDDING_MODEL=text-embedding-005
# DAMA_VERTEX_MODEL=gemini-2.5-flash
# AN1_VERTEX_MODEL=
# DAMA_MAX_OUTPUT_TOKENS=2048
# AN1_VERTEX_BUNDLE_GCS_URI=
# AN1_VERTEX_BUNDLE_PATH=
# AN1_VERTEX_MANIFEST_GCS_URI=
# AN1_VERTEX_MANIFEST_PATH=
# AN1_VERTEX_CORPUS_UPLOAD_BASE_GCS=
# DAMA_RUNTIME=

# --- DIY auth (SQLite + cookie): only active when Firebase is OFF ---
# Default is on for local dev. Set DAMA_DIY_AUTH=0 for open chat or when using Firebase below.
# DAMA_DIY_AUTH=0
# DAMA_SESSION_SECRET=change-me-long-random-string
# DAMA_SESSION_HTTPS_ONLY=0   # 0 for http://localhost or LAN http; 1 for HTTPS-only cookie (Cloud Run)
# DAMA_AUTH_DB_PATH=          # optional; default dama_users.sqlite next to an1_app.py

# --- Firebase (production): when DAMA_FIREBASE_ENABLED=1, Firebase wins — DIY login routes are disabled ---
# Per-user chat: Firestore users/{uid}/conversations. Pedagogy: users/{uid}/pedagogy_events.
# DAMA_FIREBASE_ENABLED=1
# DAMA_FIREBASE_WEB_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","appId":"..."}
# FIREBASE_PROJECT_ID=   # optional if same as GOOGLE_CLOUD_PROJECT / projectId in web config
# Cloud Run: service account needs Firebase Admin + Firestore access. Local: gcloud auth application-default login or JSON key.
# Firebase Console → Authentication: enable Email/Password, Google, etc. Firestore: create DB in same project.
