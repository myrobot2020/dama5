# Copy to .env and fill in values. Never commit .env.

# --- Optional layout overrides (defaults: files next to an1_app.py) ---
# DAMA_DATA_DIR=
# AN1_JSON_PATH=
# AN2_JSON_PATH=
# CHROMA_AN1_DIR=
# CHROMA_AN2_DIR=
# CHROMA_VALID_SUTTAS_DIR=   # merged "valid_suttas" collection (python an1_build_index.py --book valid)
# DAMA_DEBUG_LOG_PATH=
# DAMA_GONG_MP3=

# --- Vertex / GCP (optional; local Chroma works without these) ---
# AN1_USE_VERTEX=1
# DAMA_USE_VERTEX=1
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_REGION=
# GCP_PROJECT=
# GOOGLE_CLOUD_LOCATION=
# AN1_VERTEX_EMBEDDING_MODEL=text-embedding-005
# DAMA_VERTEX_MODEL=gemini-2.5-flash
# AN1_VERTEX_MODEL=
# DAMA_MAX_OUTPUT_TOKENS=2048
# AN1_VERTEX_BUNDLE_GCS_URI=
# AN1_VERTEX_BUNDLE_PATH=
# AN1_VERTEX_MANIFEST_GCS_URI=
# AN1_VERTEX_MANIFEST_PATH=
# AN1_VERTEX_CORPUS_UPLOAD_BASE_GCS=
# DAMA_RUNTIME=

# --- Teacher audio (private GCS; UI requests signed URLs) ---
# Upload MP3s to: gs://<bucket>/aud/<filename>.mp3
# DAMA_AUDIO_GCS_BUCKET=dama-aud
# DAMA_AUDIO_GCS_PREFIX=aud/
# Signed URL TTL seconds (min 60, max 3600)
# DAMA_AUDIO_URL_TTL_SECONDS=900
# Optional: explicit signer service account email (Cloud Run usually auto-detects via metadata)
# DAMA_AUDIO_SIGNER_SERVICE_ACCOUNT=

# --- DIY auth (SQLite + cookie) ---
# Default is on for local dev. Set DAMA_DIY_AUTH=0 for open chat (no login).
# DAMA_DIY_AUTH=0
# DAMA_SESSION_SECRET=change-me-long-random-string
# DAMA_SESSION_HTTPS_ONLY=0   # 0 for http://localhost or LAN http; 1 for HTTPS-only cookie (Cloud Run)
# DAMA_AUTH_DB_PATH=          # optional; default dama_users.sqlite next to an1_app.py
# Optional: CORS for separate front-end (comma-separated origins). Dev Vite proxy does not need this.
# DAMA_CORS_ORIGINS=https://your-pages-host.pages.dev,http://localhost:8080
# Optional: force timings in /api/query JSON: DAMA_SHOW_TIMINGS=1
